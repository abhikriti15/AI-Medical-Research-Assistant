# Server Configuration
NODE_ENV=development
PORT=5001
LOG_LEVEL=info

# Database
MONGO_URI=mongodb://localhost:27017/curalink

# Redis Cache
REDIS_URL=redis://localhost:6379

# LLM Configuration
OLLAMA_URL=http://localhost:11434
LLM_MODEL=mistral

# API Configuration
FRONTEND_URL=http://localhost:3003,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=30

# API Keys (optional for external services)
OPENAI_API_KEY=
HUGGINGFACE_API_KEY=

# Session Configuration
SESSION_TIMEOUT=3600000
CACHE_TTL=86400000

# Security
JWT_SECRET=your-secret-key-change-in-production
CORS_ORIGIN=http://localhost:3003,http://localhost:3000

# Logging
LOG_FORMAT=json
LOG_DIR=./logs
